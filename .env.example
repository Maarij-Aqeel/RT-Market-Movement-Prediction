# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Reddit API (PRAW) ---
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=market-pulse-predictor/0.1 by your_reddit_username

# --- NewsData.io API ---
# Free tier (200 credits/day): https://newsdata.io/
NEWSDATA_API_KEY=pub_cae90c6a172c4fdfb1edadb674cbfc42

# --- Alpha Vantage API (fallback for Yahoo Finance) ---
# Free tier (25 req/day): https://www.alphavantage.co/support/#api-key
# Used automatically when yfinance is rate-limited or blocked.
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- MLflow ---
# Local: file:./mlruns. Docker compose: http://mlflow:5000
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=market-pulse-predictor

# --- Logging ---
LOG_LEVEL=INFO
